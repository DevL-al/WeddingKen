rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userExists() {
      return signedIn() && exists(userPath());
    }

    function role() {
      return userExists() ? get(userPath()).data.role : null;
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow create: if isOwner(userId)
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role == 'customer';

      allow read: if signedIn() && (isOwner(userId) || isAdmin());

      allow update: if signedIn() && (
        isAdmin() ||
        (
          isOwner(userId) &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.email == resource.data.email
        )
      );

      allow delete: if isAdmin();
    }

    match /packages/{packageId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'Menunggu Konfirmasi'
        && request.resource.data.paymentStatus == 'Belum Bayar';

      allow read: if signedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'Menunggu Verifikasi';

      allow read: if signedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /galleries/{galleryId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
