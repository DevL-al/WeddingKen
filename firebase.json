{
  "firestore": {
    "rules": "firestore.rules"
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "weddingken-app",
          "appId": "1:52018188086:android:f4f61f7a01cc0df028ad97",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "weddingken-app",
          "configurations": {
            "android": "1:52018188086:android:f4f61f7a01cc0df028ad97",
            "web": "1:52018188086:web:d565d8d82d4dcabd28ad97"
          }
        }
      }
    }
  },
  "hosting": {
    "public": "build/web",
    "ignore": [
